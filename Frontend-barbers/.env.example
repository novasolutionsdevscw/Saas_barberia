# =============================================================================
# DESARROLLO LOCAL (copia a .env)
# =============================================================================
VITE_API_URL=/api
# IP de tu PC en la red Wi‑Fi (la muestra Vite al iniciar: Network: http://192.168.x.x:5173)
VITE_APP_URL=http://192.168.1.5:5173

# =============================================================================
# PRODUCCIÓN — usar al compilar: npm run build
# Mismo dominio (recomendado): frontend + /api + /storage en un solo sitio
# =============================================================================
# VITE_API_URL=/api
# VITE_APP_URL=https://tudominio.com

# =============================================================================
