FROM node:20-alpine AS builder
WORKDIR /app
COPY package*.json ./
RUN npm install
COPY . .

ARG VITE_API_URL
ARG VITE_APP_URL
ARG VITE_STORAGE_ORIGIN
ENV VITE_API_URL=$VITE_API_URL
ENV VITE_APP_URL=$VITE_APP_URL
ENV VITE_STORAGE_ORIGIN=$VITE_STORAGE_ORIGIN

RUN npm run build

FROM nginx:alpine
COPY --from=builder /app/dist /usr/share/nginx/html
RUN printf 'server{\nlisten 3000;\nroot /usr/share/nginx/html;\nindex index.html;\nlocation / {try_files $uri $uri/ /index.html;}\n}' > /etc/nginx/conf.d/default.conf
EXPOSE 3000
CMD ["nginx", "-g", "daemon off;"]
